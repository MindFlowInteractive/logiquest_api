# Core
DATABASE_URL=postgresql://user:password@localhost:5432/logiquest
JWT_SECRET=your_jwt_secret
JWT_EXPIRY=1h
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,https://logiquest.app

# Redis / BullMQ (required for async email queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email provider: smtp | sendgrid
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@logiquest.app

# SMTP settings (EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SendGrid settings (EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
