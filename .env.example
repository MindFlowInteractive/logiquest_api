DATABASE_URL=postgresql://user:password@localhost:5432/logiquest
JWT_SECRET=your_jwt_secret
JWT_EXPIRY=1h
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,https://logiquest.app
CALIBRATION_AUTO_APPLY=false

# Swagger / OpenAPI
# Set to "false" to disable the Swagger UI (recommended for production)
# When enabled, the interactive docs are served at http://localhost:PORT/api/docs
SWAGGER_ENABLED=true
